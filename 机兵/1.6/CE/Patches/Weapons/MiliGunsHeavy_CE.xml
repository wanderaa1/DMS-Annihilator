<?xml version="1.0" encoding="utf-8"?>

<Patch>
	<!-- ========== 聚变主炮 ========== -->
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="DMS_FusionCannon"]/tools</xpath>
		<value>
			<tools>
				<li Class="CombatExtended.ToolCE">
					<label>barrel</label>
					<capacities>
						<li>Blunt</li>
					</capacities>
					<power>10</power>
					<cooldownTime>3.0</cooldownTime>
					<armorPenetrationBlunt>3.5</armorPenetrationBlunt>
					<linkedBodyPartsGroup>Barrel</linkedBodyPartsGroup>
				</li>
			</tools>
		</value>
	</Operation>
	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="DMS_FusionCannon"]/statBases/RangedWeapon_Cooldown</xpath>
		<value>
			<RangedWeapon_Cooldown>2.5</RangedWeapon_Cooldown>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="DMS_FusionCannon"]/verbs/li/warmupTime</xpath>
		<value>
			<warmupTime>0.5</warmupTime>
		</value>
	</Operation>

	<Operation Class="PatchOperationReplace">
		<xpath>Defs/ThingDef[defName="DMS_FusionCannon"]/verbs/li/range</xpath>
		<value>
			<range>49.9</range>
		</value>
	</Operation>
	<!-- ========== 聚变机炮 ========== -->
	
	
	
	<!-- ========== 火箭巢 ========== -->
</Patch>
