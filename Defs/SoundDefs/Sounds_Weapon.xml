<?xml version="1.0" encoding="utf-8"?>
<Defs>

    <!-- 聚变主炮 -->
    <SoundDef>
        <defName>DMSA_zupao</defName>
        <context>MapOnly</context>
        <maxSimultaneous>1</maxSimultaneous>
        <subSounds>
            <li>
                <grains>
                    <li Class="AudioGrain_Clip">
                        <clipPath>DMSA_zupao</clipPath>
                    </li>
                </grains>
                <pitchRange>0.945882~1</pitchRange>
                <volumeRange>40~50</volumeRange>
            </li>
        </subSounds>
    </SoundDef>

